<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}ashton richards</title>
    <meta name="description" content="{{ description or 'Personal site and blog' }}" />
    <link rel="stylesheet" href="/assets/styles.css" />
    <link
      rel="stylesheet"
      href="https://unpkg.com/prismjs@1.29.0/themes/prism-tomorrow.min.css"
    />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="93178830-529a-4233-a285-f8988c2060b2"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="shell">
        <nav class="site-nav">
          <a href="/" class="brand">ashton richards</a>
        </nav>
      </div>
    </header>

    <main class="shell">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <div class="shell footer-inner">
        <div class="footer-left">
          <a href="/contact/">contact</a>
        </div>
        <div class="footer-right">
          © 2026 ashton richards
        </div>
      </div>
    </footer>
  </body>
</html>